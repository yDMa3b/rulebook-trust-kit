{
  "$schema": "../example.schema.json",
  "game_type": "trick-taking",
  "description": "Advisory example for trick-taking games.",
  "reference_games": ["gong-zhu", "sheng-ji", "wu-shi-fen"],
  "example_phases": [
    { "lua_id": "BIDDING", "lua_value": 1, "cpp_phase": 1, "ui_behavior": "show_phase_buttons", "button_labels": ["bid", "pass"] },
    { "lua_id": "KITTY", "lua_value": 2, "cpp_phase": 2, "ui_behavior": "show_phase_buttons", "button_labels": ["kitty", "confirm"] },
    { "lua_id": "PLAYING", "lua_value": 4, "cpp_phase": 4, "ui_behavior": "show_play_buttons", "button_labels": ["play"] },
    { "lua_id": "SETTLEMENT", "lua_value": 5, "cpp_phase": 5, "ui_behavior": "show_result_panel", "button_labels": [] }
  ],
  "history_card_types": [
    { "value": 0, "meaning": "pass", "ui_action": "show_pass_tip" },
    { "value": 1, "meaning": "single_card", "ui_action": "show_played_cards" }
  ],
  "action_mask_schema": [
    { "index": 0, "meaning": "can_pass", "ui_binding": "pass_button_enabled" },
    { "index": "1-N", "meaning": "card_index", "ui_binding": "card_selectable" }
  ],
  "required_lua_exports_extra": [],
  "forbidden_lua_exports": ["evaluate_hand", "is_winning"],
  "custom_data_layout": [
    { "offset": 0, "size": 1, "field": "trump_suit", "type": "uint8" }
  ],
  "seat_custom_layout": null,
  "seat_fields": [
    { "field": "score", "usage": "required" },
    { "field": "role", "usage": "optional" }
  ],
  "extra_cards_usage": "Kitty or bottom cards."
}
