{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pipeline Protocol Schema",
  "type": "object",
  "required": [
    "cpp_phase_enum",
    "ui_behavior_vocabulary",
    "sync_fields_contract",
    "universal_lua_exports"
  ],
  "properties": {
    "description": { "type": "string" },
    "cpp_phase_enum": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 1,
        "maximum": 5
      }
    },
    "ui_behavior_vocabulary": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true,
      "minItems": 1
    },
    "sync_fields_contract": {
      "type": "object",
      "required": [
        "arg1_phase",
        "arg2_active_seat",
        "arg3_done",
        "arg4_multiplier",
        "arg5_role_seat",
        "arg6_consecutive_passes"
      ],
      "additionalProperties": { "type": "string" }
    },
    "universal_lua_exports": {
      "type": "object",
      "required": ["required", "forbidden"],
      "properties": {
        "required": {
          "type": "array",
          "items": { "type": "string" }
        },
        "forbidden": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
