{
  "name": "rulebook-trust-kit",
  "version": "0.1.0",
  "private": false,
  "packageManager": "pnpm@10.33.0",
  "description": "Verifiable rule packages and maintainer workflows for tabletop games.",
  "license": "Apache-2.0",
  "scripts": {
    "build": "pnpm --filter @rulebook-trust/cli build",
    "test": "pnpm -r test",
    "validate": "pnpm --filter @rulebook-trust/cli validate",
    "trace": "pnpm --filter @rulebook-trust/cli trace",
    "review-pack": "pnpm --filter @rulebook-trust/cli review-pack"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "~5.6.2"
  }
}
